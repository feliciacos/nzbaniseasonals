# Anime metadata provider
# ANI = prefer AniList, with MAL fallback if MAL_CLIENT_ID is set
# MAL = prefer MyAnimeList, with AniList fallback if MAL is unavailable
APITYPE=ANI
MAL_CLIENT_ID=your_client_id_here
MAL_CLIENT_SECRET=your_client_secret_here

# Sonarr
SONARR_URL=http://YOUR_SONARR_IP:8989
SONARR_API_KEY=YOUR_API_KEY
SONARR_QUALITY_PROFILE_ID=1
SONARR_ROOT_FOLDER_PATH=YOUR_SONARR_ROOTFOLDER
SONARR_MONITOR_NEW_ITEMS=all
SONARR_SEASON_FOLDER=true

# Radarr
RADARR_URL=http://YOUR_RADARR_IP:7878
RADARR_API_KEY=YOUR_API_KEY
RADARR_QUALITY_PROFILE_ID=1
RADARR_ROOT_FOLDER_PATH=YOUR_RADARR_ROOTFOLDER
RADARR_MONITOR_NEW_ITEMS=all

# App defaults
PORT=8787
DEFAULTSEASON=current
DEFAULTSORT=Trending
ALREADYINLIB=False
PER_PAGE=20
AUTOLOAD_PAGES=4
DEFAULTTYPE=TV

# Library sync
# REFRESHONLOAD=true keeps the old behavior and refreshes Sonarr/Radarr while loading the frontend.
# REFRESHONLOAD=false uses background sync so the frontend can load from the latest cached library state.
REFRESHONLOAD=false
# Accepts xm, xh, or xd, for example 1m, 1h, 1d. Used only when REFRESHONLOAD=false.
SYNC_INTERVAL=30m
SHOW_SYNC_NOW_BUTTON=true
